{
  "name": "@cordfuse/sftp-mcp",
  "version": "0.0.1",
  "description": "SFTP as a browsable filesystem for AI agents (MCP): list, stat, move, mkdir, delete, batch, upload, download — not just upload/download. Node, stdio + streamable HTTP.",
  "type": "module",
  "bin": {
    "sftp-mcp": "dist/index.js"
  },
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sftp",
    "ftp",
    "ssh",
    "file-transfer",
    "filesystem",
    "ai-agent"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "author": "Cordfuse",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "basic-ftp": "^5.0.5",
    "ssh2-sftp-client": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ssh2-sftp-client": "^9.0.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
